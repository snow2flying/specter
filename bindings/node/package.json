{
  "name": "specters",
  "version": "3.1.0",
  "description": "Node.js bindings for Specter HTTP, WebSocket, HTTP/2, and HTTP/3 tunnel client",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "specter",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "napi build --platform --release --dts index.gen.d.ts",
    "build:debug": "napi build --platform",
    "create:npm-dirs": "napi create-npm-dirs",
    "prepublishOnly": "napi prepublish -t npm --no-gh-release",
    "artifacts": "napi artifacts --output-dir ./artifacts",
    "test": "jest"
  },
  "jest": {
    "testMatch": [
      "**/__tests__/*.test.js"
    ]
  },
  "optionalDependencies": {
    "specters-darwin-x64": "3.1.0",
    "specters-darwin-arm64": "3.1.0",
    "specters-linux-x64-gnu": "3.1.0",
    "specters-linux-arm64-gnu": "3.1.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "jest": "^29.7.0"
  },
  "keywords": [
    "http",
    "http3",
    "fingerprint",
    "tls",
    "client",
    "async",
    "native"
  ],
  "author": "Jared Boynton",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaredboynton/specter.git",
    "directory": "bindings/node"
  }
}
